{
  "name": "neon-sewer-raid-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter web dev",
    "build": "pnpm -r build",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "quality": "pnpm -r quality",
    "init": "jiti tools/init.ts",
    "validate": "jiti tools/validate.ts",
    "predev": "node tools/check-setup.js",
    "prebuild": "node tools/check-setup.js",
    "predeploy": "node tools/check-setup.js",
    "update-layer": "npx tsx tools/update-layer.ts",
    "generate:favicons": "npx tsx tools/generate-favicons.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "vue-demi",
      "workerd"
    ],
    "overrides": {
      "nuxt-og-image": "6.0.0-beta.42",
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3"
    }
  },
  "packageManager": "pnpm@10.28.0",
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0"
  }
}
